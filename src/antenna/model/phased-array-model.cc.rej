diff a/src/antenna/model/phased-array-model.cc b/src/antenna/model/phased-array-model.cc	(rejected hunks)
@@ -82,6 +82,22 @@ PhasedArrayModel::GetTypeId ()
   return tid;
 }
 
+void
+PhasedArrayModel::InitializeToBoresight ()
+{
+  // Initialize to equal weights
+  ComplexVector beamformingVector (GetNumberOfElements (), 
+                                   std::complex<double> (1.0, 0.0));
+
+  double norm = ComputeNorm (beamformingVector);
+  for (uint64_t i = 0; i < beamformingVector.size (); i++)
+    {
+      beamformingVector[i] = std::conj (beamformingVector[i]) / norm;
+    }
+  
+  m_beamformingVector = beamformingVector;
+  m_isBfVectorValid = true;
+}
 
 void
 PhasedArrayModel::SetBeamformingVector (const ComplexVector &beamformingVector)
@@ -158,6 +174,9 @@ PhasedArrayModel::SetAntennaElement (Ptr<AntennaModel> antennaElement)
 {
   NS_LOG_FUNCTION (this);
   m_antennaElement = antennaElement;
+
+  // initialize as pointing to boresight
+  InitializeToBoresight ();
 }
 
 
